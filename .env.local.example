# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your apps → Web app config

NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Optional: Stripe (for payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Optional: NextAuth (if used)
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# AI Writing Assistant (OpenAI)
# Used for AI job post writing, worker bio generation, cover letters, and CV builder.
# Only required if you want to enable AI writing features (gated behind paid subscriptions).
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Transactional Emails (Resend)
# Sign up free at https://resend.com, create an API key, and paste it here.
# Without this, all transactional emails are silently skipped — the app still works.
RESEND_API_KEY=re_your_resend_api_key

# Optional: override the From address used for all transactional emails
RESEND_FROM_EMAIL=WorkerConnect <notifications@workerconnect.co.nz>

# Secret used to sign one-click unsubscribe tokens in emails.
# Generate with: openssl rand -hex 32
# Falls back to RESEND_API_KEY in development if not set.
UNSUBSCRIBE_SECRET=your_32_char_hex_secret

# Admin Dashboard
# UID of the site owner's Firebase account — used as a secondary check in API routes.
# Get your UID from: Firebase Console → Authentication → Users
ADMIN_UID=your_firebase_uid_here
# Also exposed to the client for the layout double-check (same value, different prefix)
NEXT_PUBLIC_ADMIN_UID=your_firebase_uid_here

