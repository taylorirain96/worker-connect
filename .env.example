NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# Firebase Admin SDK — used by server-side API routes
# Option A: paste the full service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_KEY=
# Option B: individual fields (used when FIREBASE_SERVICE_ACCOUNT_KEY is not set)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
# Stripe — Dashboard → Developers → API Keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Stripe webhook signing secret — Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Resend — transactional email (job accepted, payment released, quote received)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=
# The "from" address shown on outgoing emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=QuickTrade <hello@quicktrade.co.nz>
# Base URL used in email links — set to your production domain
NEXT_PUBLIC_APP_URL=https://quicktrade.co.nz
# Mobile app API base URL (Expo)
EXPO_PUBLIC_API_BASE_URL=https://quicktrade.co.nz
UNSUBSCRIBE_SECRET=

# Auth session cookie signing secret — required in production. Used to HMAC
# the `auth-session` cookie that the route guard middleware verifies.
AUTH_SESSION_SECRET=

# MBIE trade licence verification provider (worker licences)
MBIE_LICENCE_VERIFICATION_URL=
MBIE_LICENCE_VERIFICATION_API_KEY=

# Business verification providers
BUSINESS_VERIFICATION_API_KEY=
BUSINESS_VERIFICATION_LICENSE_URL=
BUSINESS_VERIFICATION_INSURANCE_URL=
BUSINESS_VERIFICATION_BACKGROUND_URL=
BUSINESS_VERIFICATION_CERTIFICATIONS_URL=

# OpenAI
OPENAI_API_KEY=

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Admin checks
ADMIN_UID=
NEXT_PUBLIC_ADMIN_UID=

# Sentry — error monitoring + performance tracing
# DSN is split into server-side (SENTRY_DSN) and browser-side
# (NEXT_PUBLIC_SENTRY_DSN). Both may point at the same project; only the
# NEXT_PUBLIC_ one is bundled into the client.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Sentry source-map upload (used by withSentryConfig during `next build`).
# Generate an Auth Token at https://sentry.io/settings/account/api/auth-tokens/
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional — override the environment / release tag.
# Defaults to VERCEL_ENV / NODE_ENV and VERCEL_GIT_COMMIT_SHA respectively.
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_RELEASE=
# Optional — sample rate for performance traces (0.0 to 1.0). Defaults to 0.1.
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
